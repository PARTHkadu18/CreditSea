# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ── Next.js build output ──────────────────────
client/.next/
client/out/

# ── Server build output ───────────────────────
server/dist/

# ── Environment variables ─────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ──────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS artifacts ──────────────────────────────
.DS_Store
Thumbs.db

# ── Editor directories ────────────────────────
.vscode/
.idea/

# ── Uploaded files (runtime data) ────────────
server/uploads/*
!server/uploads/.gitkeep
